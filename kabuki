#!/bin/bash
source ~/Repositories/scripts/essential-functions
watch_history_yt="$HOME/Misc/Backups/video/watch-history-youtube.csv"
watch_history_docs="$HOME/Misc/Backups/video/watch-history-docs.csv"
watch_history_tv="$HOME/Misc/Backups/video/watch-history-tv.csv"
watch_history_film="$HOME/Misc/Backups/video/watch-history-film.csv"

function check-watchfile {
    [[ -z "$2" ]] && {
	echolor red ":: function check-watchfile returned an error!"
	exit 1
    }
    [[ ! -e "$1" ]] && {
	echolor yellow ":: ““$1”” created"
	echo "$2" > "$1"
    } 
}

check-watchfile "$watch_history_yt" "title,channel,duration,time"
check-watchfile "$watch_history_docs" "title,time"
check-watchfile "$watch_history_film" "title,time"
check-watchfile "$watch_history_tv" "show,episode,time"

function channel-views {
    xan select channel,duration "$watch_history_yt"        \
	| xan groupby channel 'count(channel) as views'    \
	| xan sort -NR -s views                            \
	| xan enum -S 1 -c rank
}

function channel-watchtimes {
    xan select channel,duration "$watch_history_yt"           \
	| xan groupby channel 'sum(duration) as duration'     \
	| xan sort -NR -s duration                            \
	| xan transform duration 'idiv(duration, 60)'         \
	| xan enum -S 1 -c rank
}

function redownload-video {
    redownload_id="$(xan select title "$watch_history_yt" | sort | uniq | fzf | awk -F '[' '{print $2}' | awk -F ']' '{print $1}')"
    [[ "$(wc -m <<< "$redownload_id")" != "12" ]] && {
	echolor red ":: Not a YouTube ID."
	exit 1
    }
    ThyPipe "https://www.youtube.com/watch?v=$redownload_id" &
}

case "$1" in
    "yt"|"youtube")
	xan tail -l 24 "$watch_history_yt" | xan view -s title,channel,time -HMR --cols 0.9 --color=always --theme="striped" | sed '/^$/d'
	;;
    "tv"|"show"|"shows")
	xan tail -l 24 "$watch_history_tv" | xan view -HMR --cols 0.99 --color=always --theme="striped" | sed '/^$/d'
	;;
    "doc"|"docs"|"documentaries"|"documentary")
	xan tail -l 24 "$watch_history_docs" | xan view -HMR --color=always --theme="striped" | sed '/^$/d'
	;;
    "film"|"films"|"movies"|"movie"|"mov")
	xan tail -l 24 "$watch_history_film" | xan view -HMR --color=always --theme="striped" | sed '/^$/d'
	;;
    "hist"|"history"|"all")
	echo -n "YouTube ($(xan count "$watch_history_yt"))"
	xan tail -l 4 "$watch_history_yt" | ifne xan view -s title,channel,time --cols 0.99 -HMR --color=always --theme="striped" | sed '/^$/d' 
	echo -n "TV ($(xan count "$watch_history_tv"))"
	xan tail -l 4 "$watch_history_tv" | ifne xan view --cols 0.99 -HMR --color=always --theme="striped" | sed '/^$/d'	    
	echo -n "Documentaries ($(xan count "$watch_history_docs"))"
	xan tail -l 4 "$watch_history_docs" | ifne xan view -HMR --cols 0.99 --color=always --theme="striped" | sed '/^$/d'	    
	echo -n "Films ($(xan count "$watch_history_film"))"
	xan tail -l 4 "$watch_history_film" | ifne xan view -HMR --cols 0.99 --color=always --theme="striped" | sed '/^$/d'	    
	;;
    "fav"|"star"|"stars"|"starred")
	echo '🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟'
	xan select title,channel "$watch_history_yt"             \
	    | rg -N '🌟'                                        \
	    | sed 's/🌟//g'                                     \
	    | sort                                              \
	    | uniq                                              \
	    | cut -c 18-                                        \
	    | xan view -nMR --color=always --theme="striped"
	echo '🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟🌟'
	;;
    "rank"|"channel"|"channels")
	xan cat columns                                 \
	    <(channel-views | xan select views,channel) \
	    <(channel-watchtimes)                       \
	    | xan view -MRIpAr 1
	;;
    "redownload"|"download"|"thypipe"|"pipe"|"tp")
	redownload-video
	;;
    *)
	:
	;;
esac
	

[[ -z "$1" ]] || exit
ep="$(eza --no-quotes -1fX --show-symlinks | sed '/^$/d' | sort | grep -E 'mkv$|avi$|mp4$|ts$|mov$|webm$|m4v$' | ifne fzf)"
[[ -z "$ep" ]] && exit
[[ -e "$HOME/Excluding/youtube/.${ep%mp4}json" ]] && {
    echolor white 'Title:  \t' 1
    jq -r '.title' "$HOME/Excluding/youtube/.${ep%mp4}json" | sed 1q
    echolor white 'Channel:\t' 1
    jq -r '.channel' "$HOME/Excluding/youtube/.${ep%mp4}json" | sed 1q
    echolor white 'Uploaded:\t' 1
    date -Idate -d "$(jq -r '.upload_date' "$HOME/Excluding/youtube/.${ep%mp4}json" | sed 1q)"
    echolor white 'Downloaded:\t' 1
    date -Idate -d "$(stat -c '%w' "$ep")"
    echolor white 'Times watched:\t' 1
    watch_instance="$(rg -- "$(echo "$ep" | between '[' ']')" "$watch_history_yt" | wc -l)"
    echo "$watch_instance"
    channel="$(jq -r '.channel' "$HOME/Excluding/youtube/.${ep%mp4}json" | sed 1q)"
    echolor white 'View rank:\t' 1
    echo -n "#$(channel-views | xan search -s channel -e "$channel" | xan select rank | xan behead) by views ("
    echo -n "$(channel-views | xan search -s channel -e "$channel" | xan select views | xan behead) times)"
    echo
    echolor white 'Time rank:\t' 1
    echo -n "#$(channel-watchtimes | xan search -s channel -e "$channel" | xan select rank | xan behead) by watchtime ("
    echo -n "$(channel-watchtimes | xan search -s channel -e "$channel" | xan select duration | xan behead) minutes)"
    echo
    echolor white '------------------------------------------------------'
}
[[ -e "$HOME/Excluding/youtube/.${ep%mp4}json" ]] && {
    jq -r '.description' "$HOME/Excluding/youtube/.${ep%mp4}json" | fold -sw 130
    echolor white '------------------------------------------------------'
}
mpv --msg-level=all=error --osd-fractions --volume=100 --volume-max=200 --alang=eng --slang=eng "$ep" || exit
choose_done="$(echo -e 'Mark as done\nDo nothing\nAbandon file\nDone and star' | fzf --no-input)"
ext_alone="$(echo "$ep" | awk -F '.' '{print $NF}')"
allrelatedfiles="$(echo "$ep" | sed "s/\.$ext_alone//;s/,/‚/g")"
addstar=''
[[ "$choose_done" = "Done and star" ]] && addstar='🌟'
case "$choose_done" in
    "Mark as done"|"Done and star")
	if pwd | grep -q "$HOME/Excluding/youtube"
	then
	    {
		echo -ne "$addstar$allrelatedfiles,"
		echo -ne "$(jq '.channel' "$HOME/Excluding/youtube/.$allrelatedfiles".json | sed 1q),"
		echo -ne "$(jq '.duration' "$HOME/Excluding/youtube/.$allrelatedfiles".json | sed 1q),"
		echo  -e "$(date -Isec)"
	    } >> "$watch_history_yt"
	    move-to-trash-recursively "$allrelatedfiles"* "$HOME/Excluding/youtube/.$allrelatedfiles".json
	    echolor green ":: Logged into the YouTube record $addstar"
	elif pwd | grep -q "$HOME/TV"
	then
	    {
		echo -ne "$(pwd | awk -F '/' '{print $5}'),"
		echo -ne "$(tr -d ',' <<< "$allrelatedfiles"),"
		echo -e "$(date -Isec)"
	    } >> "$watch_history_tv"
       	    move-to-trash-recursively "$allrelatedfiles"*
	    echolor green ":: Logged into the TV record"
	elif pwd | grep -q "$HOME/Excluding/documentaries"
	then
	    {
		echo -ne "$allrelatedfiles,"
		echo -e "$(date -Isec)"
	    } >> "$watch_history_docs"
	    move-to-trash-recursively "$allrelatedfiles"*
	    echolor green ":: Logged into the documentaries record"
	elif pwd | grep -q "$HOME/Films"
	then
	    {
		echo -ne "$allrelatedfiles,"
		echo -e "$(date -Isec)"
	    } >> "$watch_history_film"
	    move-to-trash-recursively "$allrelatedfiles"*
	    echolor green ":: Logged into the film record"
	else
	    echolor red ":: File is outside supported directories."
	    exit 1
	fi
	;;
    "Abandon file")
	if pwd | grep -q "$HOME/Excluding/youtube"
	then
	    move-to-trash-recursively "$allrelatedfiles"* "$HOME/Excluding/youtube/.$allrelatedfiles".json
	    echolor yellow ":: The video ““$allrelatedfiles””\n:: has been abandoned"
	elif pwd | grep -q "$HOME/TV"
	then
       	    move-to-trash-recursively "$allrelatedfiles"*
	    echolor yellow ":: The episode ““$allrelatedfiles””\n:: has been abandoned"
	elif pwd | grep -q "$HOME/Excluding/documentaries"
	then
	    move-to-trash-recursively "$allrelatedfiles"*
	    echolor yellow ":: The documentary ““$allrelatedfiles””\n:: has been abandoned"
	elif pwd | grep -q "$HOME/Films"
	then
	    move-to-trash-recursively "$allrelatedfiles"*
	    echolor yellow ":: The film ““$allrelatedfiles””\n:: has been abandoned"
	else
	    echolor red ":: File is outside supported directories."
	    exit 1
	fi
	;;
    "Do nothing")
	echolor yellow ":: Nothing was done"
	;;
esac
