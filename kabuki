#!/bin/bash
source ~/Repositories/scripts/essential-functions
watch_history_yt="$HOME/Misc/Backups/video/watch-history-youtube.csv"
watch_history_gen="$HOME/Misc/Backups/video/watch-history-general.csv"
watch_history_docs="$HOME/Misc/Backups/video/watch-history-docs.csv"
watch_history_tv="$HOME/Misc/Backups/video/watch-history-tv.csv"

case "$1" in
    "yt"|"youtube")
	tail -n 20 "$watch_history_yt" | xan view -MRn --color=always --theme="striped" | sed '/^$/d'
	;;
    "gen"|"general")
	tail -n 20 "$watch_history_gen" | xan view -MRn --color=always --theme="striped" | sed '/^$/d'
	;;
    "tv"|"show"|"shows")
	tail -n 20 "$watch_history_tv" | xan view -MRn --color=always --theme="striped" | sed '/^$/d'
	;;
    "doc"|"docs"|"documentaries"|"documentary")
	tail -n 20 "$watch_history_docs" | xan view -MRn --color=always --theme="striped" | sed '/^$/d'
	;;
    "hist"|"history"|"all")
	echo -n YouTube
	tail -n 3 "$watch_history_yt"  | xan view -MRn --color=always --theme="striped" | sed '/^$/d' 
	echo -n TV
	tail -n 3 "$watch_history_tv" | xan view -MRn --color=always --theme="striped" | sed '/^$/d'	    
	echo -n Documentaries
	tail -n 3 "$watch_history_docs" | xan view -MRn --color=always --theme="striped" | sed '/^$/d'	    
	echo -n General
	tail -n 3 "$watch_history_gen" | xan view -MRn --color=always --theme="striped" | sed '/^$/d'	    
	;;
    *)
	:
	;;
esac
	

vid_exts=
[[ -z "$1" ]] || exit

ep="$(eza --no-quotes -1fX --show-symlinks | sed '/^$/d' | sort | grep -E 'mkv$|avi$|mp4$|ts$|mov$|webm$|m4v$' | ifne fzf)"
[[ -z "$ep" ]] && {
    echolor yellow ":: No file selected."
    exit
}
[[ -e "$HOME/Excluding/youtube/.${ep%mp4}json" ]] && {
    echo -n 'Uploaded '
    date -Idate -d "$(jq -r '.upload_date' "$HOME/Excluding/youtube/.${ep%mp4}json")"
    echo -n 'Downloaded '
    date -Idate -d "$(stat -c '%w' "$ep")"
}
[[ -e "$HOME/Excluding/youtube/.${ep%mp4}json" ]] && jq -r '.description' "$HOME/Excluding/youtube/.${ep%mp4}json" | bat -pp 
mpv --osd-fractions --volume=100 --volume-max=200 --alang=eng --slang=eng "$ep" || exit
fd -q donefile && {
    echolor red ":: Found a donefile, doing nothing..."
    exit
}
pwd | grep -q "$HOME/TV" && {
    fd -q "^done$" && done_exists="y" || done_exists="n"
    } || {
    done_exists="y"
}
[[ "$done_exists" = "n" ]] && \
    choose_no_done="$(echo -e 'Create done marker\nCreate done dir\nDo nothing' | fzf --no-input)"
case "$choose_no_done" in
    "Do nothing")
	echolor yellow ":: Doing nothing."
	exit ;;
    "Create done marker")
	donetime="$(date -Isec)"
	echo -e "$ep\n$donetime" > "./donefile-$(date -d "$donetime" +"%Y-%m-%d-%H-%M")"
	echolor green ":: Done marker created:"
	echolor white "$(cat "./donefile-$(date -d "$donetime" +"%Y-%m-%d-%H-%M")")"
	exit ;;
    "Create done dir")
	mkdir -v "done"
	fd -q "^done$" && done_exists="y" || done_exists="n"
	;;
esac
[[ "$done_exists" = "y" ]] && choose_done="$(echo -e 'Move to done\nDo nothing\nAbandon file' | fzf --no-input --prompt='Move to done? ')"
ext_alone="$(echo "$ep" | awk -F '.' '{print $NF}')"
allrelatedfiles="$(echo "$ep" | sed "s/\.$ext_alone//;s/,/‚/g")"
case "$choose_done" in
    "Move to done")
	if pwd | grep -q "$HOME/Excluding/youtube"
	then
	    {
		echo -ne "$allrelatedfiles,"
		echo -ne "$(jq '.channel' "$HOME/Excluding/youtube/.$allrelatedfiles".json),"
		echo  -e "$(date -Isec)"
	    } >> "$watch_history_yt"
	    move-to-trash-recursively "$allrelatedfiles"* "$HOME/Excluding/youtube/.$allrelatedfiles".json
	    echolor green ":: Logged into the YouTube record"
	elif pwd | grep -q "$HOME/TV"
	then
	    {
		echo -ne "$(pwd | awk -F '/' '{print $5}'),"
		echo -ne "$allrelatedfiles,"
		echo -e "$(date -Isec)"
	    } >> "$watch_history_tv"
       	    mv -v "$allrelatedfiles"* done/
	    echolor green ":: Logged into the TV record"
	elif pwd | grep -q "$HOME/Excluding/documentaries"
	then
	    {
		echo -ne "$allrelatedfiles,"
		echo -e "$(date -Isec)"
	    } >> "$watch_history_docs"
	    move-to-trash-recursively "$allrelatedfiles"*
	    echolor green ":: Logged into the documentaries record"
	else
	    {
		echo -ne "$allrelatedfiles,"
		echo -e "$(date -Isec)"
	    } >> "$watch_history_gen"
	    move-to-trash-recursively "$allrelatedfiles"*
	    echolor green ":: Logged into the general record"
	fi
	;;
    "Abandon file")
	if pwd | grep -q "$HOME/Excluding/youtube"
	then
	    move-to-trash-recursively "$allrelatedfiles"* "$HOME/Excluding/youtube/.$allrelatedfiles".json
	    echolor yellow ":: The video ““$allrelatedfiles””\n:: has been abandoned"
	elif pwd | grep -q "$HOME/TV"
	then
       	    mv -v "$allrelatedfiles"* done/
	    echolor yellow ":: The episode ““$allrelatedfiles””\n:: has been abandoned"
	elif pwd | grep -q "$HOME/Excluding/documentaries"
	then
	    move-to-trash-recursively "$allrelatedfiles"*
	    echolor yellow ":: The documentary ““$allrelatedfiles””\n:: has been abandoned"
	else
	    move-to-trash-recursively "$allrelatedfiles"*
	    echolor yellow ":: The file ““$allrelatedfiles””\n:: has been abandoned"
	fi
	;;
    "Do nothing")
	echolor yellow ":: Nothing was done"
	;;
esac
